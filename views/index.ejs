<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Vedant Sareen — Cybersecurity Engineer</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@300;400;500&family=Barlow+Condensed:wght@300;400;600;700;800&display=swap" rel="stylesheet">
<style>
/* ── RESET & ROOT ── */
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;font-size:16px}
:root{
  --bg:#040810;
  --bg1:#080f1e;
  --c1:#00e5ff;
  --c2:#7c3aff;
  --c3:#00ffa3;
  --c4:#ff3366;
  --c5:#ffc233;
  --txt:#cdd8f0;
  --dim:rgba(130,160,200,0.45);
  --glass:rgba(8,18,40,0.65);
  --b1:rgba(0,229,255,0.1);
  --b2:rgba(124,58,255,0.15);
  --g1:0 0 24px rgba(0,229,255,0.18),0 0 64px rgba(0,229,255,0.06);
  --g2:0 0 24px rgba(124,58,255,0.22),0 0 64px rgba(124,58,255,0.07);
  --g3:0 0 20px rgba(0,255,163,0.18);
  --r:0.9rem;
  --ease:cubic-bezier(.16,1,.3,1);
}
body{background:var(--bg);color:var(--txt);font-family:'Syne',sans-serif;overflow-x:hidden;cursor:none}
body.no-cursor{cursor:auto}
::selection{background:rgba(0,229,255,0.15);color:#fff}
::-webkit-scrollbar{width:2px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:linear-gradient(var(--c1),var(--c2))}
img,iframe{max-width:100%}

/* ── CUSTOM CURSOR (desktop only) ── */
#cur{position:fixed;width:8px;height:8px;background:var(--c1);border-radius:50%;pointer-events:none;z-index:99999;transform:translate(-50%,-50%);mix-blend-mode:screen;box-shadow:0 0 12px var(--c1);will-change:left,top;transition:width .2s,height .2s,background .2s}
#cur-r{position:fixed;width:34px;height:34px;border:1px solid rgba(0,229,255,0.3);border-radius:50%;pointer-events:none;z-index:99998;transform:translate(-50%,-50%);will-change:left,top;transition:width .25s,height .25s,border-color .25s}
body.hov #cur{width:20px;height:20px;background:var(--c2);box-shadow:0 0 20px var(--c2)}
body.hov #cur-r{width:54px;height:54px;border-color:rgba(124,58,255,0.45)}
@media(hover:none){#cur,#cur-r{display:none}body{cursor:auto}}

/* ── PRELOADER ── */
#ldr{position:fixed;inset:0;z-index:999999;background:var(--bg);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:0}
#ldr::after{content:'';position:absolute;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 3px,rgba(0,229,255,0.008) 3px,rgba(0,229,255,0.008) 4px);pointer-events:none}
.lr{width:72px;height:72px;margin-bottom:28px;position:relative;flex-shrink:0}
.lr::before,.lr::after,.lr span{position:absolute;border-radius:50%;border-style:solid;border-color:transparent}
.lr::before{inset:0;border-width:1.5px;border-top-color:var(--c1);animation:sp 1s linear infinite;box-shadow:0 0 18px rgba(0,229,255,0.1)}
.lr span{inset:10px;border-width:1px;border-right-color:var(--c3);animation:sp 1.6s linear infinite reverse}
.lr::after{inset:20px;border-width:1px;border-bottom-color:var(--c2);animation:sp 2.2s linear infinite}
@keyframes sp{to{transform:rotate(360deg)}}
.ln{font-family:'Barlow Condensed',sans-serif;font-size:clamp(28px,5vw,58px);font-weight:800;letter-spacing:12px;background:linear-gradient(135deg,#fff 0%,var(--c1) 50%,var(--c2) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;opacity:0;transform:translateY(16px)}
.lrole{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:5px;color:rgba(130,160,200,0.45);margin-top:6px;opacity:0}
.lbar{width:200px;height:1px;background:rgba(0,229,255,0.08);margin-top:36px;overflow:hidden;position:relative}
.lbar-f{height:100%;width:0;background:linear-gradient(90deg,var(--c1),var(--c2),var(--c3));transition:width .05s linear;position:relative}
.lbar-f::after{content:'';position:absolute;right:0;top:-2px;width:4px;height:5px;background:var(--c1);border-radius:50%;box-shadow:0 0 8px var(--c1)}
.lpct{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--c1);margin-top:10px;letter-spacing:3px}
.lmsg{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--dim);margin-top:5px;letter-spacing:2px;height:13px}

/* ── BG LAYERS ── */
canvas#bg{position:fixed;inset:0;z-index:0;pointer-events:none}
.vgn{position:fixed;inset:0;z-index:1;pointer-events:none;background:radial-gradient(ellipse 80% 80% at 50% 50%,transparent 30%,rgba(4,8,16,0.8) 100%)}
.scl{position:fixed;inset:0;z-index:1;pointer-events:none;background:repeating-linear-gradient(0deg,transparent,transparent 2px,rgba(0,0,0,0.012) 2px,rgba(0,0,0,0.012) 4px)}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:1000;height:60px;padding:0 clamp(16px,4vw,64px);display:flex;align-items:center;justify-content:space-between;transition:background .35s,border-color .35s;border-bottom:1px solid transparent}
nav.stuck{background:rgba(4,8,16,0.92);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-color:rgba(0,229,255,0.07)}
.logo{font-family:'Barlow Condensed',sans-serif;font-size:20px;font-weight:800;letter-spacing:4px;color:var(--c1);text-decoration:none;position:relative;flex-shrink:0}
.logo::after{content:'VEDANT SAREEN';position:absolute;left:0;top:calc(100% + 1px);font-size:7px;letter-spacing:3px;color:var(--dim);font-family:'JetBrains Mono',monospace;white-space:nowrap}
.nav-links{display:flex;gap:clamp(12px,2vw,28px);list-style:none;align-items:center}
.nav-links a{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:2px;color:var(--dim);text-decoration:none;transition:color .25s;padding-bottom:3px;position:relative}
.nav-links a::after{content:'';position:absolute;bottom:0;left:0;width:0;height:1px;background:linear-gradient(90deg,var(--c1),var(--c2));transition:width .35s}
.nav-links a:hover,.nav-links a.act{color:var(--txt)}
.nav-links a:hover::after,.nav-links a.act::after{width:100%}
.nav-links a.act{color:var(--c1)}
.nav-cta{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:2px;color:var(--c1);text-decoration:none;border:1px solid rgba(0,229,255,0.2);padding:7px 16px;transition:all .28s;clip-path:polygon(5px 0,100% 0,calc(100% - 5px) 100%,0 100%)}
.nav-cta:hover{background:rgba(0,229,255,0.07);box-shadow:var(--g1);border-color:rgba(0,229,255,0.4)}
.ham{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:none;padding:3px}
.ham span{display:block;width:20px;height:1px;background:var(--c1);transition:.3s}

/* ── MOBILE OVERLAY ── */
.mob{position:fixed;inset:0;z-index:9999;background:rgba(4,8,16,0.97);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:28px;transform:translateX(101%);transition:transform .5s var(--ease)}
.mob.open{transform:none}
.mob a{font-family:'Barlow Condensed',sans-serif;font-size:clamp(32px,7vw,52px);font-weight:700;letter-spacing:6px;color:var(--txt);text-decoration:none;transition:color .25s}
.mob a:hover{color:var(--c1)}
.mob-x{position:absolute;top:20px;right:20px;background:none;border:none;color:var(--dim);font-size:24px;cursor:none;transition:color .25s}
.mob-x:hover{color:var(--c1)}

/* ── SECTION BASE ── */
section{position:relative;z-index:3;padding:clamp(64px,8vw,120px) clamp(16px,5vw,80px)}
.sec-tag{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:4px;color:var(--c1);display:flex;align-items:center;gap:10px;margin-bottom:10px}
.sec-tag::before{content:'';width:24px;height:1px;background:linear-gradient(90deg,var(--c1),transparent)}
.sec-h{font-family:'Barlow Condensed',sans-serif;font-weight:800;font-size:clamp(36px,6vw,80px);letter-spacing:2px;line-height:.95;text-transform:uppercase}
.sec-h em{font-style:normal;-webkit-text-stroke:1.5px var(--c1);-webkit-text-fill-color:transparent;color:transparent}
.sec-div{width:40px;height:2px;background:linear-gradient(90deg,var(--c1),var(--c2));margin-top:14px;margin-bottom:clamp(32px,5vw,56px)}

/* ── REVEAL SYSTEM ── */
.rv{opacity:0;transform:translateY(28px);transition:opacity .65s var(--ease),transform .65s var(--ease)}
.rv.on{opacity:1;transform:none}
.rv-l{opacity:0;transform:translateX(-28px);transition:opacity .65s var(--ease),transform .65s var(--ease)}
.rv-l.on{opacity:1;transform:none}
.rv-r{opacity:0;transform:translateX(28px);transition:opacity .65s var(--ease),transform .65s var(--ease)}
.rv-r.on{opacity:1;transform:none}

/* ── HERO ── */
#hero{min-height:100svh;display:flex;align-items:center;padding-top:80px;overflow:hidden}
.h-inner{width:100%;max-width:1400px;margin:0 auto;display:grid;grid-template-columns:1fr min(400px,42%);gap:clamp(24px,4vw,64px);align-items:center}
.h-status{display:inline-flex;align-items:center;gap:8px;font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:3px;color:var(--c3);margin-bottom:clamp(14px,2vw,22px);opacity:0}
.h-status i{width:6px;height:6px;background:var(--c3);border-radius:50%;box-shadow:0 0 8px var(--c3);animation:blink 2s infinite;flex-shrink:0}
@keyframes blink{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(1.4)}}
.h-name{font-family:'Barlow Condensed',sans-serif;font-size:clamp(58px,11vw,152px);font-weight:800;line-height:.84;letter-spacing:1px;text-transform:uppercase;opacity:0;transform:translateY(60px)}
.h-name .n1{display:block;color:#fff}
.h-name .n2{display:block;background:linear-gradient(90deg,var(--c1) 0%,var(--c2) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;position:relative}
/* glitch */
.h-name .n2.g::before{content:'SAREEN';position:absolute;left:0;top:0;background:inherit;-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;clip-path:polygon(0 15%,100% 15%,100% 35%,0 35%);transform:translateX(-3px);opacity:.7}
.h-name .n2.g::after{content:'SAREEN';position:absolute;left:0;top:0;background:linear-gradient(90deg,var(--c4),var(--c2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;clip-path:polygon(0 65%,100% 65%,100% 82%,0 82%);transform:translateX(3px);opacity:.6}
.h-role{font-family:'JetBrains Mono',monospace;font-size:clamp(10px,1.2vw,13px);letter-spacing:3px;color:var(--dim);margin-top:clamp(10px,1.5vw,18px);height:20px;opacity:0}
.h-role .cursor{color:var(--c1);animation:bk .9s steps(1) infinite}
@keyframes bk{0%,100%{opacity:1}50%{opacity:0}}
.h-desc{font-size:clamp(13px,1.4vw,15px);line-height:1.85;color:var(--dim);max-width:520px;margin-top:clamp(10px,1.5vw,18px);opacity:0}
.h-desc strong{color:var(--c1);font-weight:600}
.h-btns{display:flex;flex-wrap:wrap;gap:10px;margin-top:clamp(18px,2.5vw,30px);opacity:0}
.btn-p{display:inline-flex;align-items:center;gap:7px;font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:2.5px;padding:12px 22px;text-decoration:none;cursor:none;clip-path:polygon(6px 0,100% 0,calc(100% - 6px) 100%,0 100%);transition:all .3s;background:linear-gradient(135deg,var(--c1),var(--c2));color:#000;font-weight:500;position:relative;overflow:hidden}
.btn-p::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,var(--c2),var(--c1));opacity:0;transition:opacity .3s}
.btn-p span{position:relative;z-index:1}
.btn-p:hover::before{opacity:1}.btn-p:hover{transform:translateY(-2px);box-shadow:var(--g1)}
.btn-o{display:inline-flex;align-items:center;gap:7px;font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:2.5px;padding:11px 22px;text-decoration:none;cursor:none;clip-path:polygon(6px 0,100% 0,calc(100% - 6px) 100%,0 100%);transition:all .3s;border:1px solid rgba(0,229,255,0.2);color:var(--c1)}
.btn-o:hover{background:rgba(0,229,255,0.07);border-color:var(--c1);transform:translateY(-2px);box-shadow:var(--g1)}
.h-stats{display:flex;flex-wrap:wrap;gap:clamp(16px,2.5vw,32px);margin-top:clamp(22px,3vw,36px);padding-top:clamp(18px,2.5vw,28px);border-top:1px solid rgba(0,229,255,0.07);opacity:0}
.stat .v{font-family:'Barlow Condensed',sans-serif;font-size:clamp(34px,4vw,52px);font-weight:800;line-height:1;background:linear-gradient(135deg,var(--c1),var(--c2));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.stat .l{font-family:'JetBrains Mono',monospace;font-size:8px;letter-spacing:2px;color:var(--dim);margin-top:2px}
/* terminal */
.term{background:rgba(4,10,24,0.9);border:1px solid rgba(0,229,255,0.1);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);border-radius:12px;overflow:hidden;opacity:0;transform:translateX(40px);box-shadow:0 24px 48px rgba(0,0,0,.5)}
.term-bar{display:flex;align-items:center;gap:6px;padding:10px 14px;background:rgba(0,0,0,.35);border-bottom:1px solid rgba(0,229,255,0.07)}
.dot{width:9px;height:9px;border-radius:50%}
.dot:nth-child(1){background:#ff5f57}.dot:nth-child(2){background:#febc2e}.dot:nth-child(3){background:#28c840}
.term-title{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--dim);margin-left:6px;letter-spacing:2px}
.term-body{padding:16px 18px;font-family:'JetBrains Mono',monospace;font-size:11px;line-height:2}
.tl{display:block}
.tl .p{color:var(--c3)}.tl .c{color:var(--txt)}.tl .k{color:var(--dim);padding-left:12px}.tl .v{color:var(--c1)}.tl .v2{color:var(--c2)}.tl .ok{color:var(--c3)}.tl .dim{color:rgba(58,84,120,.6)}
.tl.bl::after{content:'▮';color:var(--c1);animation:bk .9s steps(1) infinite;margin-left:3px}
.scroll-cue{position:absolute;bottom:24px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:6px;opacity:0;z-index:5}
.scroll-cue span{font-family:'JetBrains Mono',monospace;font-size:8px;letter-spacing:4px;color:var(--dim)}
.scroll-line{width:1px;height:36px;background:linear-gradient(to bottom,var(--c1),transparent);animation:sl 2s ease-in-out infinite}
@keyframes sl{0%,100%{opacity:1}50%{opacity:.2}}

/* ── ABOUT ── */
.ab-grid{display:grid;grid-template-columns:clamp(260px,28%,320px) 1fr;gap:clamp(24px,4vw,56px);align-items:start}
.ab-card{background:var(--glass);border:1px solid var(--b1);border-radius:14px;padding:clamp(18px,2.5vw,26px);position:relative;overflow:hidden;backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px)}
.ab-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,var(--c1),var(--c2),transparent)}
.ab-card::after{content:'';position:absolute;inset:0;background:radial-gradient(circle at 85% 0%,rgba(0,229,255,0.04),transparent 60%);pointer-events:none}
.ab-hd{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:3px;color:var(--c1);margin-bottom:16px;display:flex;align-items:center;gap:7px}
.ab-hd::before{content:'';width:7px;height:7px;border-radius:50%;background:var(--c1);box-shadow:0 0 8px var(--c1)}
.pr{display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid rgba(0,229,255,0.04)}
.pr:last-child{border:none}
.pk{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--dim);letter-spacing:1px}
.pv{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--txt)}
.pv.a1{color:var(--c1)}.pv.a2{color:var(--c3)}.pv.a3{color:var(--c5)}
.ab-text p{font-size:clamp(13px,1.3vw,15px);line-height:1.9;color:var(--dim);margin-bottom:14px}
.ab-text p strong{color:var(--txt);font-weight:600}
.highlight-box{background:rgba(0,255,163,0.04);border:1px solid rgba(0,255,163,0.12);border-radius:10px;padding:14px 18px;margin-top:18px}
.highlight-box p{font-size:13px;line-height:1.8;color:rgba(0,255,163,.6);margin:0}
.highlight-box strong{color:var(--c3)}
.tags{display:flex;flex-wrap:wrap;gap:6px;margin-top:16px}
.tag{font-family:'JetBrains Mono',monospace;font-size:9px;padding:4px 10px;border:1px solid rgba(124,58,255,0.18);color:var(--dim);border-radius:4px;transition:all .2s;cursor:default}
.tag:hover{border-color:var(--c2);color:var(--c2);background:rgba(124,58,255,0.07)}

/* ── SKILLS ── */
#skills{background:linear-gradient(180deg,transparent,rgba(0,10,28,.15) 50%,transparent)}
.sk-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.sk-card{background:var(--glass);border:1px solid var(--b1);border-radius:12px;padding:clamp(14px,2vw,22px);position:relative;overflow:hidden;transition:transform .3s,border-color .3s,box-shadow .3s}
.sk-card::after{content:'';position:absolute;inset:0;background:radial-gradient(circle at var(--mx,50%) var(--my,50%),rgba(0,229,255,0.06),transparent 52%);opacity:0;transition:opacity .3s;pointer-events:none}
.sk-card:hover{border-color:rgba(0,229,255,0.2);transform:translateY(-4px);box-shadow:0 14px 40px rgba(0,0,0,.4)}
.sk-card:hover::after{opacity:1}
.sk-ic{font-size:18px;margin-bottom:10px}
.sk-t{font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:3px;color:var(--c1);margin-bottom:10px}
.sk-chips{display:flex;flex-wrap:wrap;gap:5px}
.sk-ch{font-family:'JetBrains Mono',monospace;font-size:8px;padding:3px 7px;background:rgba(0,229,255,0.04);border:1px solid rgba(0,229,255,0.09);color:rgba(180,210,255,.45);border-radius:3px;transition:all .2s}
.sk-ch:hover{border-color:var(--c1);color:var(--c1);background:rgba(0,229,255,0.09)}
.bars-wrap{margin-top:clamp(32px,4vw,52px)}
.bars-title{font-family:'JetBrains Mono',monospace;font-size:10px;letter-spacing:3px;color:var(--c2);margin-bottom:20px}
.bar-row{margin-bottom:12px}
.bar-meta{display:flex;justify-content:space-between;margin-bottom:4px}
.bar-n{font-family:'JetBrains Mono',monospace;font-size:10px;color:var(--txt)}
.bar-p{font-family:'JetBrains Mono',monospace;font-size:9px;color:var(--c1)}
.bar-t{height:2px;background:rgba(0,229,255,0.07);border-radius:2px;overflow:hidden}
.bar-f{height:100%;width:0;border-radius:2px;transition:width 1.4s var(--ease)}
.bar-f.a{background:linear-gradient(90deg,var(--c1),var(--c2))}
.bar-f.b{background:linear-gradient(90deg,var(--c2),var(--c4))}
.bar-f.c{background:linear-gradient(90deg,var(--c3),var(--c1))}

/* ── PROJECTS ── */
#projects{background:linear-gradient(180deg,transparent,rgba(0,0,18,.1) 50%,transparent)}
.proj-intro{font-family:'JetBrains Mono',monospace;font-size:12px;color:var(--dim);margin-bottom:28px;line-height:1.8}
.proj-intro a{color:var(--c1);text-decoration:none;border-bottom:1px solid rgba(0,229,255,0.2);transition:border-color .2s}
.proj-intro a:hover{border-color:var(--c1)}
.proj-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,340px),1fr));gap:18px}
.pc{background:var(--glass);border:1px solid var(--b1);border-radius:14px;overflow:hidden;position:relative;transition:transform .35s,border-color .35s,box-shadow .35s;transform-style:preserve-3d;cursor:none}
.pc::before{content:'';position:absolute;inset:0;background:radial-gradient(circle at var(--mx,50%) var(--my,50%),rgba(0,229,255,0.042),transparent 52%);opacity:0;transition:opacity .35s;z-index:0;pointer-events:none}
.pc:hover{border-color:rgba(0,229,255,0.24);transform:translateY(-5px);box-shadow:0 24px 52px rgba(0,0,0,.5),var(--g1)}
.pc:hover::before{opacity:1}
.pc-body{padding:clamp(16px,2vw,24px) clamp(16px,2vw,24px) 0;position:relative;z-index:1}
.pc-head{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:10px}
.badge{font-family:'JetBrains Mono',monospace;font-size:8px;letter-spacing:2.5px;padding:3px 10px;border-radius:20px}
.badge.ai{background:rgba(124,58,255,0.12);border:1px solid rgba(124,58,255,0.25);color:var(--c2)}
.badge.net{background:rgba(0,229,255,0.07);border:1px solid rgba(0,229,255,0.18);color:var(--c1)}
