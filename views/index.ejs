.ps::before{content:'';width:4px;height:4px;border-radius:50%;flex-shrink:0}
.ps.live{color:var(--c3)}.ps.live::before{background:var(--c3);box-shadow:0 0 6px var(--c3);animation:blink 2s infinite}
.ps.prog{color:var(--c5)}.ps.prog::before{background:var(--c5)}
.ps.done{color:var(--dim)}.ps.done::before{background:var(--dim)}
.ps.pat{color:var(--c2)}.ps.pat::before{background:var(--c2);animation:blink 2s infinite}

/* ── RESEARCH ── */
#research{background:linear-gradient(180deg,transparent,rgba(14,0,40,.14) 50%,transparent)}
.res-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,280px),1fr));gap:18px}
.rc{background:var(--glass);border:1px solid var(--b2);border-radius:14px;padding:clamp(18px,2vw,26px);position:relative;overflow:hidden;transition:transform .35s,border-color .35s,box-shadow .35s}
.rc::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:linear-gradient(90deg,transparent,var(--c2),transparent);transform:scaleX(0);transition:transform .4s}
.rc::after{content:'';position:absolute;inset:0;background:radial-gradient(circle at 50% 0%,rgba(124,58,255,0.06),transparent 65%);opacity:0;transition:opacity .35s;pointer-events:none}
.rc:hover{transform:translateY(-5px);border-color:rgba(124,58,255,.35);box-shadow:0 20px 48px rgba(0,0,0,.5),var(--g2)}
.rc:hover::before{transform:scaleX(1)}.rc:hover::after{opacity:1}
