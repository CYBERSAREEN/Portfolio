.pc-foot{padding:10px clamp(16px,2vw,24px) 16px;border-top:1px solid rgba(0,229,255,0.06);display:flex;align-items:center;gap:7px;flex-wrap:wrap;position:relative;z-index:1}
.pl{display:inline-flex;align-items:center;gap:4px;font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:1.5px;padding:6px 11px;border-radius:4px;text-decoration:none;transition:all .25s;cursor:none}
.pl.g{border:1px solid rgba(0,229,255,0.16);color:var(--c1)}
.pl.g:hover{background:rgba(0,229,255,0.07);border-color:var(--c1);transform:translateY(-2px);box-shadow:var(--g1)}
.pl.r{border:1px solid rgba(124,58,255,0.18);color:var(--c2)}
