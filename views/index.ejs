.rc-desc{font-size:12px;line-height:1.8;color:rgba(180,210,255,.38);margin-top:8px}
.rc-a{display:inline-flex;align-items:center;gap:5px;font-family:'JetBrains Mono',monospace;font-size:9px;letter-spacing:1px;color:var(--c1);text-decoration:none;margin-top:14px;padding:6px 12px;border:1px solid rgba(0,229,255,0.14);border-radius:4px;transition:all .25s;cursor:none}
