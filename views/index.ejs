.rc-type{font-family:'JetBrains Mono',monospace;font-size:8px;letter-spacing:3px;padding:4px 11px;border-radius:20px;background:rgba(124,58,255,0.1);border:1px solid rgba(124,58,255,0.22);color:var(--c2);display:inline-block;margin-bottom:13px}
